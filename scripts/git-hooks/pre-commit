#!/usr/bin/env bash
# RGX pre-commit gate-receipt guard.
#
# Blocks committing a *gate-affecting* tree (Rust / Cargo / CI /
# scripts) unless `./scripts/run-local-ci.sh` exited 0 for exactly
# this content (proven by a fresh matching receipt). Doc-only /
# pgen-issues-only commits are allowed without a receipt — they
# cannot change a Rust gate result.
#
# Activate once per clone:  ./scripts/setup-hooks.sh
# Last-resort bypass:       git commit --no-verify   (must be
#   justified in the commit body per COMMIT.md — never a silent
#   default).
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
# shellcheck source=scripts/lib-gate-receipt.sh
. "$repo_root/scripts/lib-gate-receipt.sh"

gate_pathspec=(
  '--' '*.rs' '*/Cargo.toml' 'Cargo.toml' 'Cargo.lock'
  '*/build.rs' '.github/workflows/*' 'scripts/*'
  'rgx-capi/cbindgen.toml' 'rgx-capi/include/*'
  ':(exclude)subs/pgen' ':(exclude)git_message_brief.txt'
)

# Does this commit touch any gate-affecting path?
staged_gate_files="$(git diff --cached --name-only "${gate_pathspec[@]}")"
if [ -z "$staged_gate_files" ]; then
  # Pure docs / pgen-issues / non-gate commit — nothing the local
  # Rust gate could catch. Allow.
  exit 0
fi

receipt="$(rgx_receipt_path)"
if [ ! -f "$receipt" ]; then
  cat >&2 <<'EOF'
✗ pre-commit blocked: no green gate receipt.

This commit changes gate-affecting files (Rust / Cargo / CI /
scripts) but ./scripts/run-local-ci.sh has not been run green for
this content. The mandatory gate is the FULL suite on the default
thread stack (lib + integration incl. tests/stress_tests.rs + doc) —
a filtered/`--lib`/`| tail`-masked run is NOT the gate (see
COMMIT.md, and the 2026-05-18 deep-nesting incident).

Fix: ./scripts/run-local-ci.sh   (then re-commit)
Last resort, justified in the commit body: git commit --no-verify
EOF
  exit 1
fi

want="$(cat "$receipt")"
have="$(rgx_gate_state_id)"
if [ "$want" != "$have" ]; then
  cat >&2 <<'EOF'
✗ pre-commit blocked: stale gate receipt.

Gate-affecting files changed since ./scripts/run-local-ci.sh last
passed, so the green you have does not certify what you are about to
commit. Re-run the gate against the current tree.

Fix: ./scripts/run-local-ci.sh   (then re-commit)
Last resort, justified in the commit body: git commit --no-verify
EOF
  exit 1
fi

echo "✓ pre-commit: gate receipt fresh and matching."
exit 0
